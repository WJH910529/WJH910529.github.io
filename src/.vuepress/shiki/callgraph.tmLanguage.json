{
  "name": "callgraph",
  "scopeName": "source.callgraph",
  "patterns": [
    {
      "name": "meta.callgraph.entry",
      "match": "\\[([^\\]:]+\\.[^\\]:]+):(\\d+)(?:-(\\d+))?\\]\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "string.other.link" },
        "2": { "name": "constant.numeric.integer" },
        "3": { "name": "constant.numeric.integer" },
        "4": { "name": "entity.name.function" }
      }
    }
  ]
}
