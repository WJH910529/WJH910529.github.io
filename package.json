{
  "name": "wjh-blog",
  "description": "WJH Blog built with VuePress Theme Hope",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:vite": "vuepress-vite build src",
    "build:webpack": "vuepress-webpack build src",
    "dev": "vuepress-vite dev src",
    "dev:vite-clean": "vuepress-vite dev src --clean-cache",
    "dev:webpack": "vuepress-webpack dev src",
    "dev:webpack-clean": "vuepress-webpack dev src --clean-cache",
    "deploy": "corepack pnpm run build:vite && gh-pages -d ./src/.vuepress/dist --nojekyll -r git@github.com:WJH910529/WJH910529.github.io.git"
  },
  "dependencies": {
    "@mathjax/src": "4.1.2",
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "@vuepress/bundler-webpack": "2.0.0-rc.30",
    "@vuepress/plugin-append-date": "2.0.0-rc.130",
    "@vuepress/plugin-cache": "2.0.0-rc.130",
    "@vuepress/plugin-docsearch": "2.0.0-rc.130",
    "@vuepress/plugin-feed": "2.0.0-rc.130",
    "@vuepress/plugin-pwa": "2.0.0-rc.130",
    "@vuepress/plugin-revealjs": "2.0.0-rc.130",
    "@waline/client": "3.13.0",
    "flowchart.ts": "3.0.1",
    "gh-pages": "^6.3.0",
    "mermaid": "11.15.0",
    "reveal.js": "6.0.1",
    "sass-embedded": "1.100.0",
    "sass-loader": "16.0.8",
    "vue": "3.5.34",
    "vuepress": "2.0.0-rc.30",
    "vuepress-theme-hope": "2.0.0-rc.107"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "markdownlint-cli2": "0.18.1",
    "prettier": "3.6.2"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "^0.25.6"
    }
  }
